--- a/mqx/mqx/source/psp/coldfire/asm_mac.h
+++ b/mqx/mqx/source/psp/coldfire/asm_mac.h
@@ -26,7 +26,40 @@
 #ifndef __asm_mac_cw_h__
 #define __asm_mac_cw_h__ 1
 
-#if defined(__CWARM__)
+#if defined(__GNUC__) && !defined(__CWCC__)
+/*
+ * GCC / GAS macros for ColdFire assembly.
+ *
+ * ELF targets do not prepend underscore to C symbols.
+ * ASM_EQUATE uses GAS ".equ symbol, value" syntax.
+ * Assemble .S files with:  -Wa,--register-prefix-optional
+ */
+#define ASM_PREFIX(x)     x
+
+#define ASM_EQUATE(label,value)  .equ label, value
+#define ASM_EXTERN(label)        .extern ASM_PREFIX(label)
+#define ASM_ALIGN(value)         .balign value
+#define ASM_PUBLIC(label)        .global ASM_PREFIX(label)
+#define ASM_CONST16(value)       .short value
+#define ASM_CONST32(value)       .long value
+#define ASM_LABEL(label)         label:
+#define ASM_LABEL_CONST32(label,value) ASM_LABEL(label) ASM_CONST32(value)
+#define ASM_CODE_SECTION(name)   .section name, "ax"
+#define ASM_DATA_SECTION(name)   .section name, "aw"
+#define ASM_END                  .end
+#define ASM_COMP_SPECIFIC_DIRECTIVES
+
+#define ASM_PUBLIC_BEGIN(name)
+#define ASM_PUBLIC_FUNC(name)
+#define ASM_PUBLIC_END(name)
+
+#elif defined(__CWARM__)
 #define ASM_PREFIX(x)	x
 #else
 #define ASM_PREFIX(x) 	_##x 
